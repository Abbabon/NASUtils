# Copy to .env and adjust for your NAS.
# cp .env.example .env

# Image to run. Keep the existing local build, or switch to e.g.
# jellyfin/jellyfin:10.10.7 to use the official upstream image.
JELLYFIN_IMAGE=jellyfin-jellyfin-1-1-1:20260220

# Memory ceiling. DS423 has 2 GB total; leave headroom for DSM.
# Lower this (e.g. 1280m) if DSM gets sluggish during scans; raise it
# if you add RAM.
JELLYFIN_MEM_LIMIT=1536m

# IANA timezone (e.g. Asia/Jerusalem, Europe/London, America/New_York).
TZ=UTC

# Host paths (from the running container's volume mounts).
JELLYFIN_CONFIG=/volume2/docker/jellyfin/config
JELLYFIN_CACHE=/volume2/docker/jellyfin/cache
MEDIA_STREAM=/volume1/Stream
MEDIA_FLAC=/volume1/FLAC
